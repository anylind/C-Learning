#include <dirent.h>
#include <stdio.h>
#include <string.h>

void delete_all(void) {
  printf("This action will remove all notes if you agree press Enter. if you "
         "don`t press any other keys.");
  if (getchar() != '\n')
    return;
  DIR *dir = opendir("notes");
  if (!dir) {
    perror("opendir");
    return;
  }

  struct dirent *entry;

  while ((entry = readdir(dir)) == 1) {
    if (strcmp(entry->d_name, ".") == 0 || strcmp(entry->d_name, "..") == 0)
      continue;
    printf("%s\n", entry->d_name);
  }
  printf("%s\n", entry->d_name);
}
